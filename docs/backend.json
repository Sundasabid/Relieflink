{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Represents a user's public profile.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "role": { "type": "string" },
        "lastDonationDate": { "type": "string", "format": "date-time" },
        "availability": { "type": "boolean" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "HelpRequest": {
      "title": "Help Request",
      "description": "A request for assistance.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["Medical", "Rescue", "Blood", "Other"] },
        "location": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "accepted", "completed"] },
        "bloodType": { "type": "string" },
        "acceptedBy": { "type": "string" }
      },
      "required": ["userId", "title", "description", "type", "location", "createdAt"]
    },
    "Volunteer": {
      "title": "Volunteer",
      "description": "Volunteer information.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "skills": { "type": "string" },
        "availability": { "type": "string" },
        "location": { "type": "string" }
      },
      "required": ["userId", "skills", "availability", "location"]
    },
    "Donor": {
      "title": "Donor",
      "description": "Blood donor information.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "bloodType": { "type": "string" },
        "availability": { "type": "string" },
        "location": { "type": "string" }
      },
      "required": ["userId", "bloodType", "availability", "location"]
    },
    "Donation": {
      "title": "Donation",
      "description": "A record of a blood donation.",
      "type": "object",
      "properties": {
        "donorId": { "type": "string" },
        "requestId": { "type": "string" },
        "donationDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "completed"] }
      },
      "required": ["donorId", "requestId", "donationDate", "status"]
    }
  },
  "auth": {
    "providers": ["anonymous", "google.com", "password", "phone"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile documents."
    },
    "/requests/{requestId}": {
      "schema": { "$ref": "#/entities/HelpRequest" },
      "description": "Help request documents."
    },
    "/volunteers/{userId}": {
      "schema": { "$ref": "#/entities/Volunteer" },
      "description": "Volunteer registration documents."
    },
    "/donors/{userId}": {
      "schema": { "$ref": "#/entities/Donor" },
      "description": "Blood donor registration documents."
    },
    "/donations/{donationId}": {
      "schema": { "$ref": "#/entities/Donation" },
      "description": "Donation history documents."
    }
  }
}
