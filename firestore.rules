/**
 * @file Firebase Security Rules for Firestore.
 *
 * @core_philosophy This ruleset enforces a strict user-ownership model for user profiles
 * and volunteer/donor registrations. Help requests, donations, and task histories are publicly
 * readable but writable only by authenticated users with proper authorization (e.g., matching user ID).
 * Admin access is not defined, and will require an explicit role based implementation.
 *
 * @data_structure
 * - /users/{userId}: User profile information, accessible only by the user themselves.
 * - /requests/{requestId}: Help requests, publicly readable but writable only by the user.
 * - /volunteers/{userId}: Volunteer information, accessible only by the user themselves.
 * - /donors/{userId}: Donor information, accessible only by the user themselves.
 * - /donations/{donationId}: Donation records, publicly readable, but writable only by the user.
 * - /taskHistory/{taskId}: Task history records, publicly readable, but writable only by the user.
 *
 * @key_security_decisions
 * - User listing is disallowed to protect privacy.
 * - Data validation is relaxed for rapid prototyping but focuses on ownership checks.
 * - Admin roles are currently undefined.
 *
 * @denormalization_for_authorization
 *  - Each document needing restricted write access includes a `userId` or similar field.
 *    This avoids needing to perform expensive `get()` operations in the rules.
 *
 * @structural_segregation
 *  - There is no distinction between private and public user data. All user data is considered private
 *    and stored under the /users/{userId} path.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the existing owner of the document.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description User profile documents.
     * @path /users/{userId}
     * @allow (create) User with UID 'user123' can create their profile.
     * @allow (get) User with UID 'user123' can read their profile.
     * @deny (create) User with UID 'user456' cannot create a profile for 'user123'.
     * @deny (update) User with UID 'user456' cannot update the profile of 'user123'.
     * @deny (delete) User with UID 'user456' cannot delete the profile of 'user123'.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.uid == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.uid == resource.data.uid;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Help request documents.
     * @path /requests/{requestId}
     * @allow (get) Any user can read a help request.
     * @allow (list) Any user can list help requests.
     * @allow (create) User with UID 'user123' can create a help request with userId 'user123'.
     * @deny (create) User with UID 'user456' cannot create a help request with userId 'user123'.
     * @deny (update) User with UID 'user456' cannot update a help request created by 'user123'.
     * @deny (delete) User with UID 'user456' cannot delete a help request created by 'user123'.
     * @principle Public read, owner-only writes, validates creator ID on create, immutable creator ID.
     */
    match /requests/{requestId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(resource.data.userId);
    }

    /**
     * @description Volunteer registration documents.
     * @path /volunteers/{userId}
     * @allow (create) User with UID 'user123' can create their volunteer profile.
     * @allow (get) User with UID 'user123' can read their volunteer profile.
     * @deny (create) User with UID 'user456' cannot create a volunteer profile for 'user123'.
     * @deny (update) User with UID 'user456' cannot update the volunteer profile of 'user123'.
     * @deny (delete) User with UID 'user456' cannot delete the volunteer profile of 'user123'.
     * @principle Enforces document ownership for writes.
     */
    match /volunteers/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Blood donor registration documents.
     * @path /donors/{userId}
     * @allow (create) User with UID 'user123' can create their donor profile.
     * @allow (get) User with UID 'user123' can read their donor profile.
     * @deny (create) User with UID 'user456' cannot create a donor profile for 'user123'.
     * @deny (update) User with UID 'user456' cannot update the donor profile of 'user123'.
     * @deny (delete) User with UID 'user456' cannot delete the donor profile of 'user123'.
     * @principle Enforces document ownership for writes.
     */
    match /donors/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Donation history documents.
     * @path /donations/{donationId}
     * @allow (get) Any user can read a donation record.
     * @allow (list) Any user can list donation records.
     * @allow (create) Authenticated user can create donation records.
     * @deny (update) Non-owner cannot update a donation record.
     * @deny (delete) Non-owner cannot delete a donation record.
     * @principle Public read, owner-only writes.
     */
    match /donations/{donationId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
         * @description Task history documents.
         * @path /taskHistory/{taskId}
         * @allow (get) Any user can read a task history record.
         * @allow (list) Any user can list task history records.
         * @allow (create) Authenticated user can create task history records.
         * @deny (update) Non-owner cannot update a task history record.
         * @deny (delete) Non-owner cannot delete a task history record.
         * @principle Public read, owner-only writes.
         */
    match /taskHistory/{taskId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn();
        allow update: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
        allow delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }
  }
}