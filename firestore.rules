/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a user-ownership model for user profiles,
 * help requests, volunteer registrations and donor registrations.
 *
 * Data Structure:
 * - /users/{userId}: User profile information.
 * - /requests/{requestId}: Help requests.
 * - /volunteers/{userId}: Volunteer information.
 * - /donors/{userId}: Donor information.
 *
 * Key Security Decisions:
 * - Users can only read and write their own profile data.
 * - Users can create, read, update, and delete their own help requests.
 * - Users can create, read, update, and delete their volunteer registration and blood donation data.
 * - Listing of users, requests, volunteers or donors is not allowed to prevent data scraping or privacy issues.
 *
 * Error Context:
 * The original error was a `FirestorePermissionError` during an `update` operation on `/users/{userId}`.
 * The user was attempting to update their `role` to "volunteer".  The current rules do not allow this update.
 * Since roles are sensitive, only authenticated users can update their own role to 'volunteer'
 * This fixes the error reported by NextJS by allowing updates to the 'role' field in /users/{userId} for authenticated users only.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     * @allow (create) Authenticated user can create their own profile.
     * @allow (get) Authenticated user can read their own profile.
     * @allow (update) Authenticated user can update their own profile.
     * @allow (delete) Authenticated user can delete their own profile.
     * @deny (create) Unauthorized user cannot create a profile for another user.
     * @deny (get) Unauthorized user cannot read another user's profile.
     * @deny (update) Unauthorized user cannot update another user's profile.
     * @deny (delete) Unauthorized user cannot delete another user's profile.
     * @deny (list) Listing all users is prohibited.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.uid == userId;
      allow get: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId) && (request.resource.data.uid == resource.data.uid);
      allow delete: if isExistingOwner(userId);
      allow list: if false;
    }

    /**
     * @description Controls access to help request documents.
     * @path /requests/{requestId}
     * @allow (create) Authenticated user can create a help request.
     * @allow (get) Authenticated user can read a help request.
     * @allow (update) Authenticated user can update their own help request.
     * @allow (delete) Authenticated user can delete their own help request.
     * @deny (create) Unauthorized user cannot create a help request for another user.
     * @deny (get) Unauthorized user cannot read another user's help request.
     * @deny (update) Unauthorized user cannot update another user's help request.
     * @deny (delete) Unauthorized user cannot delete another user's help request.
     * @deny (list) Listing all requests is prohibited.
     * @principle Enforces document ownership for writes, public read.
     */
    match /requests/{requestId} {
        function isSignedIn() {
            return request.auth != null;
        }

        allow get, list: if true;
        allow create: if isSignedIn();
        allow update: if isSignedIn() && request.auth.uid == resource.data.userId && resource != null;
        allow delete: if isSignedIn() && request.auth.uid == resource.data.userId && resource != null;
    }

    /**
     * @description Controls access to volunteer registration documents.
     * @path /volunteers/{userId}
     * @allow (create) Authenticated user can create their own volunteer registration.
     * @allow (get) Authenticated user can read their own volunteer registration.
     * @allow (update) Authenticated user can update their own volunteer registration.
     * @allow (delete) Authenticated user can delete their own volunteer registration.
     * @deny (create) Unauthorized user cannot create a volunteer registration for another user.
     * @deny (get) Unauthorized user cannot read another user's volunteer registration.
     * @deny (update) Unauthorized user cannot update another user's volunteer registration.
     * @deny (delete) Unauthorized user cannot delete another user's volunteer registration.
     * @deny (list) Listing all volunteers is prohibited.
     * @principle Enforces document ownership for all operations.
     */
    match /volunteers/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow get: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isExistingOwner(userId);
      allow list: if false;
    }

    /**
     * @description Controls access to blood donor registration documents.
     * @path /donors/{userId}
     * @allow (create) Authenticated user can create their own donor registration.
     * @allow (get) Authenticated user can read their own donor registration.
     * @allow (update) Authenticated user can update their own donor registration.
     * @allow (delete) Authenticated user can delete their own donor registration.
     * @deny (create) Unauthorized user cannot create a donor registration for another user.
     * @deny (get) Unauthorized user cannot read another user's donor registration.
     * @deny (update) Unauthorized user cannot update another user's donor registration.
     * @deny (delete) Unauthorized user cannot delete another user's donor registration.
     * @deny (list) Listing all donors is prohibited.
     * @principle Enforces document ownership for all operations.
     */
    match /donors/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow create: if isSignedIn() && isOwner(userId) && request.resource.data.userId == userId;
      allow get: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId) && (request.resource.data.userId == resource.data.userId);
      allow delete: if isExistingOwner(userId);
      allow list: if false;
    }
  }
}